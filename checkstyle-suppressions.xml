<!DOCTYPE suppressions PUBLIC
        "-//Checkstyle//DTD SuppressionFilter Configuration 1.0//EN"
        "https://checkstyle.org/dtds/suppressions_1_0.dtd">

<suppressions>
    <!-- Suppressing Javadoc until we can find a good balance for this -->
    <suppress checks="Javadoc" files="."/>

    <!-- Handles the fact that sentences could be like 'AThing" from Gherkin -->
    <suppress checks="Abbreviation" files="Steps.java"/>
    <suppress checks="AbbreviationAsWordInName" files="StepsContext.java"/>

    <!-- This will suppress the characters coming in Cucumber auto generated method names -->
    <suppress checks="MethodName" files="Steps.java"/>
    <suppress checks="MethodName" files="StepsContext.java"/>

    <!-- This will suppress the @Given/When/Then that are too long -->
    <suppress checks="LineLength" files="Steps.java"/>
</suppressions>